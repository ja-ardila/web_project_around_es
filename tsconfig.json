{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./public",

    "module": "es6",
    "target": "es2022",
    "lib": ["ES2022", "DOM"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

    "allowJs": false
  },
  "include": ["src/**/*.ts"]
}
